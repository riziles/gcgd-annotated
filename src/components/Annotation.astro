---
// Annotation.astro — Inline annotation with hover tooltip
// Usage in MDX:
//   import Annotation from '../../components/Annotation.astro';
//   <Annotation text="The <b>explanation</b> that appears on hover. <a href='...'>Learn more</a>">highlighted term</Annotation>
export interface Props {
	text: string;
}

const { text } = Astro.props;
---

<span class="annotated">
	<slot />
	<span class="annotated-tooltip" role="tooltip" set:html={text} />
</span>

<style>
	.annotated {
		position: relative;
		cursor: help;
		border-bottom: 1.5px dotted var(--sl-color-text-accent, oklch(0.6 0.2 260));
		text-decoration: none;
		color: inherit;
		transition: border-color 0.2s ease;
	}

	.annotated:hover,
	.annotated:focus-within {
		border-bottom-color: var(--sl-color-text-accent, oklch(0.5 0.25 260));
		border-bottom-style: solid;
	}

	.annotated-tooltip {
		position: absolute;
		bottom: calc(100% + 8px);
		left: 50%;
		transform: translateX(-50%) translateY(4px);
		opacity: 0;
		visibility: hidden;
		white-space: normal;
		width: max-content;
		max-width: 360px;
		padding: 10px 14px;
		background: var(--sl-color-bg-nav, oklch(0.2 0 0));
		color: var(--sl-color-text, oklch(0.95 0 0));
		border: 1px solid var(--sl-color-hairline, oklch(0.35 0 0));
		border-radius: 8px;
		font-size: 0.875rem;
		line-height: 1.5;
		font-weight: 400;
		box-shadow:
			0 4px 16px rgba(0, 0, 0, 0.25),
			0 0 0 1px rgba(255, 255, 255, 0.05);
		text-align: left;
		z-index: 100;
		pointer-events: none;
		transition:
			opacity 0.2s ease,
			visibility 0.2s ease,
			transform 0.2s ease;
	}

	/* Links inside tooltips */
	.annotated-tooltip :global(a) {
		color: var(--sl-color-text-accent, oklch(0.7 0.2 260));
		text-decoration: underline;
	}

	/* Arrow */
	.annotated-tooltip::after {
		content: '';
		position: absolute;
		top: 100%;
		left: 50%;
		transform: translateX(-50%);
		border: 6px solid transparent;
		border-top-color: var(--sl-color-bg-nav, oklch(0.2 0 0));
	}

	.annotated:hover .annotated-tooltip,
	.annotated:focus-within .annotated-tooltip {
		opacity: 1;
		visibility: visible;
		transform: translateX(-50%) translateY(0);
		pointer-events: auto;
	}

	/* Mobile: tap to show */
	@media (hover: none) {
		.annotated {
			cursor: default;
		}

		.annotated:active .annotated-tooltip {
			opacity: 1;
			visibility: visible;
			transform: translateX(-50%) translateY(0);
			pointer-events: auto;
		}
	}
</style>

<script>
	function repositionTooltips() {
		document.querySelectorAll('.annotated-tooltip').forEach((tooltip) => {
			const el = tooltip as HTMLElement;
			const rect = el.getBoundingClientRect();
			if (rect.left < 8) {
				el.style.left = '0';
				el.style.transform = 'translateY(4px)';
				const parent = el.parentElement;
				if (parent) {
					parent.addEventListener('mouseenter', () => { el.style.transform = 'translateY(0)'; }, { once: true });
					parent.addEventListener('mouseleave', () => { el.style.transform = 'translateY(4px)'; });
				}
			}
			if (rect.right > window.innerWidth - 8) {
				el.style.left = 'auto';
				el.style.right = '0';
				el.style.transform = 'translateY(4px)';
			}
		});
	}
	repositionTooltips();
	window.addEventListener('resize', repositionTooltips);
</script>
